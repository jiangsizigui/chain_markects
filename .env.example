# ============================================
#  区块链预测市场平台 - 环境配置模板
# ============================================
# 复制此文件为 .env 并填入实际值

# ========== 服务器配置 ==========
PORT=3000
NODE_ENV=development

# ========== 区块链配置 ==========
# 部署合约用的私钥（危险！不要提交到 Git！）
# 测试网建议用单独的测试账号，不要用有真实资产的私钥
PRIVATE_KEY=your_private_key_here

# Polygon Mumbai 测试网 RPC（免费获取: https://rpc.maticvigil.co/ 或 https://rpc.ankr.com/polygon_mumbai）
POLYGON_MUMBAI_RPC_URL=https://rpc-mumbai.maticvigil.com

# Polygon Mainnet RPC（生产环境使用）
POLYGON_MAINNET_RPC_URL=https://polygon-rpc.com

# 已部署的合约地址（部署后更新）
REACT_APP_PMT_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000
REACT_APP_PREDICTION_MARKET_ADDRESS=0x0000000000000000000000000000000000000000

# ========== AI 配置 ==========
# 🌟 硅基流动 SiliconFlow（推荐，国内直连，2000万 tokens/月免费）
# 获取地址: https://www.siliconflow.cn/ （注册后 API Keys 页面获取）
SILICONFLOW_API_KEY=your_siliconflow_api_key_here

# 阿里云通义千问（百炼平台，有免费额度）
# 获取地址: https://bailian.console.aliyun.com/
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# 智谱 GLM（免费额度）
# 获取地址: https://open.bigmodel.cn/
ZHIPU_API_KEY=your_zhipu_api_key_here

# 月之暗面 Moonshot（免费额度）
# 获取地址: https://platform.moonshot.cn/
MOONSHOT_API_KEY=your_moonshot_api_key_here

# DeepSeek（注册送 tokens）
# 获取地址: https://platform.deepseek.com/
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Gemini API Key（需代理）
# 获取地址: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI API Key（可选，备用）
OPENAI_API_KEY=your_openai_api_key_here

# 阿里云通义千问 API Key（可选）
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# ========== 搜索引擎配置（用于 AI 联网检索） ==========
# Tavily API Key（https://app.tavily.com）
TAVILY_API_KEY=your_tavily_api_key_here

# SerpAPI Key（https://serpapi.com）
SERPAPI_API_KEY=your_serpapi_key_here

# Bing Search API Key
BING_SEARCH_API_KEY=your_bing_api_key_here

# ========== Hyperledger Fabric 自建链配置 ==========
# 是否启用 Fabric（设为 false 启用 Mock 模式，使用本地 SQLite 存储）
# 部署 Docker 网络后改为 true
FABRIC_ENABLED=false

# Fabric 连接配置文件路径（运行 fabric\03-start-fabric-network.ps1 后自动生成）
# Windows 路径示例（部署后会在脚本输出中显示实际路径）:
FABRIC_CONNECTION_PROFILE=D:\毕业\blockchain-prediction-market-platform\fabric\connection-profiles\connection-org1.json

# Fabric 钱包路径（包含 admin.id 身份文件）
FABRIC_WALLET_PATH=D:\毕业\blockchain-prediction-market-platform\fabric\wallet

# Fabric 身份名称（默认使用 Org1 管理员）
FABRIC_IDENTITY=admin

# Fabric 通道名称（test-network 默认通道）
FABRIC_CHANNEL=mychannel

# Fabric 链码名称
FABRIC_CHAINCODE=predictionmarket

# ========== 管理员配置 ==========
# 管理员初始化密钥（用于添加管理员）
ADMIN_SECRET=your_admin_secret_here

# ========== Gas 报告（可选） ==========
REPORT_GAS=true
COINMARKETCAP_API_KEY=your_coinmarketcap_api_key_here

# ========== PolygonScan 验证（可选） ==========
POLYGONSCAN_API_KEY=your_polygonscan_api_key_here
